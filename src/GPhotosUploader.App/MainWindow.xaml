<Window x:Class="GPhotosUploader.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:GPhotosUploader.App.Localization"
        Title="Google Photos Local Uploader"
        Height="780" Width="1100" MinHeight="640" MinWidth="920"
        WindowStartupLocation="CenterScreen">
    <DockPanel Margin="12">

        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Text="{Binding StateText}" FontWeight="Bold" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Text="{Binding StatusMessage}" />
            </StatusBarItem>
        </StatusBar>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Configuration -->
            <GroupBox Grid.Row="0" Header="{l:Loc Main_Config_Header}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Main_RootFolderLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,6" />
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding RootFolder, Mode=OneWay}"
                             IsReadOnly="True" VerticalAlignment="Center" Margin="0,0,8,6" />
                    <Button Grid.Row="0" Grid.Column="2" Content="{l:Loc Main_Browse}"
                            Command="{Binding BrowseFolderCommand}" Margin="0,0,8,6" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Main_GoogleAccountLabel}"
                               VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding AccountStatusText}"
                               VerticalAlignment="Center" FontWeight="SemiBold" />
                    <Button Grid.Row="1" Grid.Column="2" Content="{l:Loc Main_Connect}"
                            Command="{Binding ConnectCommand}"
                            CommandParameter="{Binding ElementName=ClientSecretBox}" />
                    <Button Grid.Row="1" Grid.Column="3" Content="{l:Loc Main_Disconnect}"
                            Command="{Binding DisconnectCommand}" Margin="0" />
                </Grid>
            </GroupBox>

            <!-- Actions -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="{l:Loc Main_ScanButton}" Command="{Binding ScanCommand}" FontWeight="Bold" />
                <Button Content="{l:Loc Main_StartButton}" Command="{Binding StartCommand}" FontWeight="Bold" />
                <Button Content="{l:Loc Main_Pause}" Command="{Binding PauseCommand}" />
                <Button Content="{l:Loc Main_Resume}" Command="{Binding ResumeCommand}" />
                <Button Content="{l:Loc Main_Stop}" Command="{Binding StopCommand}" />
            </StackPanel>

            <!-- Progression -->
            <GroupBox Grid.Row="2" Header="{l:Loc Main_Progress_Header}">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <ProgressBar Value="{Binding GlobalProgress, Mode=OneWay}" Maximum="100" Height="22" />
                        <TextBlock Text="{Binding GlobalProgressText}" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontWeight="SemiBold" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <TextBlock Text="{l:Loc Main_DetectedLabel}" /><TextBlock Text="{Binding TotalFiles}" FontWeight="Bold" />
                        <TextBlock Text="{l:Loc Main_PendingLabel}" /><TextBlock Text="{Binding PendingCount}" FontWeight="Bold" />
                        <TextBlock Text="{l:Loc Main_UploadedLabel}" /><TextBlock Text="{Binding UploadedCount}" FontWeight="Bold" Foreground="Green" />
                        <TextBlock Text="{l:Loc Main_SkippedLabel}" /><TextBlock Text="{Binding SkippedCount}" FontWeight="Bold" Foreground="DarkOrange" />
                        <TextBlock Text="{l:Loc Main_ErrorsLabel}" /><TextBlock Text="{Binding ErrorCount}" FontWeight="Bold" Foreground="Firebrick" />
                    </StackPanel>

                    <ProgressBar Value="{Binding CurrentFileProgress, Mode=OneWay}" Maximum="100" Margin="0,0,0,4" />
                    <TextBlock Text="{Binding CurrentFileText}" Margin="0,0,0,4" TextTrimming="CharacterEllipsis" />

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ThroughputText}" Margin="0,0,20,0" />
                        <TextBlock Text="{Binding EtaText}" />
                    </StackPanel>

                    <TextBlock Text="{Binding LastError}" Foreground="Firebrick" TextWrapping="Wrap"
                               Margin="0,4,0,0" TextTrimming="CharacterEllipsis" MaxHeight="40" />
                </StackPanel>
            </GroupBox>

            <!-- Onglets -->
            <TabControl Grid.Row="3">

                <TabItem Header="{l:Loc Tab_Journal}">
                    <ListBox ItemsSource="{Binding LogLines}" FontFamily="Consolas" FontSize="12"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True" />
                </TabItem>

                <TabItem Header="{l:Loc Tab_FileDetails}">
                    <DockPanel Margin="6">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="{l:Loc Main_FilterLabel}" VerticalAlignment="Center" />
                            <ComboBox ItemsSource="{Binding FilterOptions}" DisplayMemberPath="Label"
                                      SelectedItem="{Binding SelectedFilter}"
                                      Width="220" Margin="0,0,10,0" />
                            <Button Content="{l:Loc Main_Refresh}" Command="{Binding RefreshDetailsCommand}" />
                            <Button Content="{l:Loc Main_RetryFailed}" Command="{Binding ResetFailedCommand}" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding FileRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  EnableRowVirtualization="True" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{l:Loc Col_File}" Binding="{Binding FileName}" Width="200" />
                                <DataGridTextColumn Header="{l:Loc Col_Status}" Binding="{Binding StatusText}" Width="160" />
                                <DataGridTextColumn Header="{l:Loc Col_Size}" Binding="{Binding SizeText}" Width="80" />
                                <DataGridTextColumn Header="{l:Loc Col_UploadedAt}" Binding="{Binding UploadedText}" Width="130" />
                                <DataGridTextColumn Header="{l:Loc Col_ErrorReason}" Binding="{Binding ErrorText}" Width="260" />
                                <DataGridTextColumn Header="{l:Loc Col_Path}" Binding="{Binding LocalPath}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="{l:Loc Tab_History}">
                    <DockPanel Margin="6">
                        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,6">
                            <Button Content="{l:Loc Main_Refresh}" Command="{Binding RefreshHistoryCommand}" />
                            <Button Content="{l:Loc Main_ExportLog}" Command="{Binding ExportLogCommand}" />
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding BatchRows}" AutoGenerateColumns="False" IsReadOnly="True"
                                  GridLinesVisibility="Horizontal" HeadersVisibility="Column">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{l:Loc Col_Batch}" Binding="{Binding Id}" Width="60" />
                                <DataGridTextColumn Header="{l:Loc Col_Started}" Binding="{Binding CreatedText}" Width="140" />
                                <DataGridTextColumn Header="{l:Loc Col_Completed}" Binding="{Binding CompletedText}" Width="140" />
                                <DataGridTextColumn Header="{l:Loc Col_Files}" Binding="{Binding FileCount}" Width="80" />
                                <DataGridTextColumn Header="{l:Loc Col_Succeeded}" Binding="{Binding SuccessCount}" Width="80" />
                                <DataGridTextColumn Header="{l:Loc Col_Failed}" Binding="{Binding FailureCount}" Width="80" />
                                <DataGridTextColumn Header="{l:Loc Col_Status}" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </TabItem>

                <TabItem Header="{l:Loc Tab_Settings}">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="10" MaxWidth="720" HorizontalAlignment="Left">

                            <TextBlock Text="{l:Loc Settings_AuthHeader}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,8" Text="{l:Loc Settings_AuthIntro}" />
                            <Button Content="{l:Loc Settings_WizardButton}"
                                    Command="{Binding OpenOAuthWizardCommand}" HorizontalAlignment="Left"
                                    FontWeight="Bold" Margin="0,0,0,10" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Settings_ClientIdLabel}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding OAuthClientId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Settings_ClientSecretLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="ClientSecretBox" />
                            </Grid>

                            <TextBlock Text="{l:Loc Settings_UploadHeader}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6" />
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="320" />
                                    <ColumnDefinition Width="120" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="{l:Loc Settings_BatchSizeLabel}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding BatchSize, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="{l:Loc Settings_MaxRetriesLabel}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MaxRetries, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="{l:Loc Settings_ConcurrencyLabel}" VerticalAlignment="Center" Margin="0,0,8,6" />
                                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Concurrency, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="{l:Loc Settings_MaxFileSizeLabel}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding MaxFileSizeMb, UpdateSourceTrigger=PropertyChanged}" />
                            </Grid>

                            <TextBlock Text="{l:Loc Settings_FormatsHeader}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,4" Text="{l:Loc Settings_FormatsIntro}" />
                            <TextBox Text="{Binding IncludedExtensions, UpdateSourceTrigger=PropertyChanged}"
                                     TextWrapping="Wrap" AcceptsReturn="False" Margin="0,0,0,12" />

                            <Button Content="{l:Loc Settings_SaveButton}" Command="{Binding SaveSettingsCommand}"
                                    HorizontalAlignment="Left" Margin="0,0,0,16" FontWeight="Bold" />

                            <Separator Margin="0,0,0,10" />

                            <TextBlock Text="{l:Loc Settings_DuplicatesHeader}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6" />
                            <Border Background="#FFF4E5" BorderBrush="DarkOrange" BorderThickness="1"
                                    CornerRadius="4" Padding="10" Margin="0,0,0,16">
                                <TextBlock Text="{l:Loc Disclaimer_Duplicates}" TextWrapping="Wrap" />
                            </Border>

                            <TextBlock Text="{l:Loc Settings_LocalDataHeader}" FontSize="15" FontWeight="Bold" Margin="0,0,0,6" />
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6" Text="{l:Loc Settings_LocalDataIntro}" />
                            <Button Content="{l:Loc Settings_DeleteDataButton}"
                                    Command="{Binding DeleteDataCommand}" HorizontalAlignment="Left"
                                    Foreground="Firebrick" Margin="0,0,0,10" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>
        </Grid>
    </DockPanel>
</Window>
